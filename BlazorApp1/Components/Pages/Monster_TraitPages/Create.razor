@page "/monster_traits/create"
@using Microsoft.EntityFrameworkCore
@using ClassLibrary1
@using Microsoft.AspNetCore.Components.Web
@inject IDbContextFactory<BlazorApp1.Data.BlazorApp1Context> DbFactory
@inject NavigationManager NavigationManager

@rendermode RenderMode.InteractiveServer

<PageTitle>Assign Trait</PageTitle>

<div class="page-container">
    <h1 class="page-title">Assign Trait to Monster</h1>
    <p style="color:var(--text-secondary)">What makes this monster special?</p>

    <div class="ability-card" style="max-width: 600px;">
        <EditForm Model="MonsterTrait" OnValidSubmit="AddMonsterTrait">
            <DataAnnotationsValidator />
            <ValidationSummary class="text-danger" role="alert" />

            <div class="form-group">
                <label class="form-label">Monster:</label>
                <InputSelect @bind-Value="MonsterTrait.Monster_ID" class="form-control">
                    <option value="0">-- Select a Monster --</option>
                    @foreach (var m in MonstersList)
                    {
                        <option value="@m.ID">@m.Name</option>
                    }
                </InputSelect>
                <ValidationMessage For="() => MonsterTrait.Monster_ID" class="text-danger" />
            </div>

            <div class="form-group">
                <label class="form-label">Trait (Özellik):</label>
                <InputSelect @bind-Value="MonsterTrait.Trait_ID" class="form-control">
                    <option value="0">-- Select Trait --</option>
                    @foreach (var t in TraitsList)
                    {
                        <option value="@t.ID">@t.Trait_Name</option>
                    }
                </InputSelect>
                <ValidationMessage For="() => MonsterTrait.Trait_ID" class="text-danger" />
            </div>

            <div style="margin-top: 2rem; display:flex; gap: 10px;">
                <button type="submit" class="btn-action btn-primary">Assign</button>
                <a href="/monster_traits" class="btn-action btn-secondary">Cancel</a>
            </div>
        </EditForm>
    </div>
</div>

@code {
    public Monster_Traits MonsterTrait { get; set; } = new();

    private List<Monster> MonstersList = new();
    private List<Trait> TraitsList = new();

    protected override async Task OnInitializedAsync()
    {
        using var context = DbFactory.CreateDbContext();

        // Listeleri çekerken tekil isimleri kullanıyoruz
        MonstersList = await context.Monster.OrderBy(m => m.Name).ToListAsync();
        TraitsList = await context.Trait.OrderBy(t => t.Trait_Name).ToListAsync();
    }

    private async Task AddMonsterTrait()
    {
        using var context = DbFactory.CreateDbContext();

        // Ekleme yaparken context.Monster_Traits kullanıyoruz
        context.Monster_Traits.Add(MonsterTrait);
        await context.SaveChangesAsync();
        NavigationManager.NavigateTo("/monster_traits");
    }
}