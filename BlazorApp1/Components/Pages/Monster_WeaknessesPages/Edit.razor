@page "/monster_weaknesses/edit"
@using Microsoft.EntityFrameworkCore
@using ClassLibrary1
@using Microsoft.AspNetCore.Components.Web
@inject IDbContextFactory<BlazorApp1.Data.BlazorApp1Context> DbFactory
@inject NavigationManager NavigationManager

@rendermode RenderMode.InteractiveServer

<PageTitle>Edit</PageTitle>

<div class="page-container">
    <h1 class="page-title">Edit Weakness Rule</h1>

    @if (MonsterWeaknesses is null)
    {
        <p><em>Loading...</em></p>
    }
    else
    {
        <div class="ability-card" style="max-width: 600px;">
            <EditForm Model="MonsterWeaknesses" OnValidSubmit="UpdateMonsterWeaknesses">
                <DataAnnotationsValidator />
                <ValidationSummary role="alert" />

                <div class="form-group">
                    <label class="form-label" style="color:var(--text-secondary)">ID (Read-only):</label>
                    <input type="text" class="form-control" value="@MonsterWeaknesses.ID" disabled readonly style="background-color: #2a2a2a; color: #888;" />
                </div>

                <div class="form-group">
                    <label class="form-label">Monster:</label>
                    <InputSelect @bind-Value="MonsterWeaknesses.Monster_ID" class="form-control">
                        @foreach (var m in MonstersList)
                        {
                            <option value="@m.ID">@m.Name</option>
                        }
                    </InputSelect>
                </div>

                <div class="form-group">
                    <label class="form-label">Weakness Type:</label>
                    <InputSelect @bind-Value="MonsterWeaknesses.DamageType_ID" class="form-control">
                        @foreach (var d in DamageTypesList)
                        {
                            <option value="@d.ID">@d.Type_Name</option>
                        }
                    </InputSelect>
                </div>

                <div style="margin-top: 2rem; display:flex; gap: 10px;">
                    <button type="submit" class="btn-action btn-primary">Save</button>
                    <a href="/monster_weaknesses" class="btn-action btn-secondary">Cancel</a>
                </div>
            </EditForm>
        </div>
    }
</div>

@code {
    [SupplyParameterFromQuery]
    private int ID { get; set; }

    public Monster_Weaknesses? MonsterWeaknesses { get; set; }

    private List<Monster> MonstersList = new();
    private List<Damage_Type> DamageTypesList = new();

    protected override async Task OnInitializedAsync()
    {
        using var context = DbFactory.CreateDbContext();

        MonsterWeaknesses = await context.Monster_Weaknesses.FirstOrDefaultAsync(m => m.ID == ID);

        MonstersList = await context.Monster.OrderBy(m => m.Name).ToListAsync();
        DamageTypesList = await context.Damage_Type.OrderBy(d => d.Type_Name).ToListAsync();

        if (MonsterWeaknesses is null)
        {
            NavigationManager.NavigateTo("notfound");
        }
    }

    private async Task UpdateMonsterWeaknesses()
    {
        using var context = DbFactory.CreateDbContext();
        context.Attach(MonsterWeaknesses!).State = EntityState.Modified;

        try
        {
            await context.SaveChangesAsync();
        }
        catch (DbUpdateConcurrencyException)
        {
            if (!context.Monster_Weaknesses.Any(e => e.ID == MonsterWeaknesses!.ID))
            {
                NavigationManager.NavigateTo("notfound");
            }
            else
            {
                throw;
            }
        }
        NavigationManager.NavigateTo("/monster_weaknesses");
    }
}