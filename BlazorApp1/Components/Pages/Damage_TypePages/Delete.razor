@page "/damage_types/delete"
@using Microsoft.EntityFrameworkCore
@using ClassLibrary1
@using Microsoft.AspNetCore.Components.Web
@inject IDbContextFactory<BlazorApp1.Data.BlazorApp1Context> DbFactory
@inject NavigationManager NavigationManager

@rendermode RenderMode.InteractiveServer

<PageTitle>Delete</PageTitle>

<div class="page-container">
    <h1 class="page-title" style="color:var(--danger-color)">Delete Damage Type</h1>
    <p>Are you sure you want to delete this damage type?</p>

    @if (DamageType is null)
    {
        <p><em>Loading...</em></p>
    }
    else
    {
        <div class="ability-card" style="border-left: 5px solid var(--danger-color);">
            <div class="details-list">
                <div class="details-label">ID</div>
                <div class="details-value">@DamageType.ID</div>

                <div class="details-label">Type Name</div>
                <div class="details-value">@DamageType.Type_Name</div>
            </div>

            <div style="margin-top: 2rem; display:flex; gap: 10px;">
                <button @onclick="DeleteDamageType" class="btn-action btn-danger">Yes, Delete</button>
                <a href="/damage_types" class="btn-action btn-secondary">No, Cancel</a>
            </div>
        </div>
    }
</div>

@code {
    [SupplyParameterFromQuery]
    private int ID { get; set; }

    public Damage_Type? DamageType { get; set; }

    protected override async Task OnInitializedAsync()
    {
        using var context = DbFactory.CreateDbContext();
        DamageType = await context.Damage_Type.FirstOrDefaultAsync(m => m.ID == ID);

        if (DamageType is null)
        {
            NavigationManager.NavigateTo("notfound");
        }
    }

    private async Task DeleteDamageType()
    {
        using var context = DbFactory.CreateDbContext();
        context.Damage_Type.Remove(DamageType!);
        await context.SaveChangesAsync();
        NavigationManager.NavigateTo("/damage_types");
    }
}