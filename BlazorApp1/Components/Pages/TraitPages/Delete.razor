@page "/traits/delete"
@using Microsoft.EntityFrameworkCore
@using ClassLibrary1
@using Microsoft.AspNetCore.Components.Web
@inject IDbContextFactory<BlazorApp1.Data.BlazorApp1Context> DbFactory
@inject NavigationManager NavigationManager

@rendermode RenderMode.InteractiveServer

<PageTitle>Delete</PageTitle>

<div class="page-container">
    <h1 class="page-title" style="color:var(--danger-color)">Delete Trait</h1>
    <p>Are you sure you want to delete this trait?</p>

    @if (Trait is null)
    {
        <p><em>Loading...</em></p>
    }
    else
    {
        <div class="ability-card" style="border-left: 5px solid var(--danger-color);">
            <div class="details-list">
                <div class="details-label">ID</div>
                <div class="details-value">@Trait.ID</div>

                <div class="details-label">Trait Name</div>
                <div class="details-value">@Trait.Trait_Name</div>
            </div>

            <div style="margin-top: 2rem; display:flex; gap: 10px;">
                <button @onclick="DeleteTrait" class="btn-action btn-danger">Yes, Delete</button>
                <a href="/traits" class="btn-action btn-secondary">No, Cancel</a>
            </div>
        </div>
    }
</div>

@code {
    [SupplyParameterFromQuery]
    private int ID { get; set; }

    public Trait? Trait { get; set; }

    protected override async Task OnInitializedAsync()
    {
        using var context = DbFactory.CreateDbContext();
        Trait = await context.Trait.FirstOrDefaultAsync(m => m.ID == ID);

        if (Trait is null)
        {
            NavigationManager.NavigateTo("notfound");
        }
    }

    private async Task DeleteTrait()
    {
        using var context = DbFactory.CreateDbContext();
        context.Trait.Remove(Trait!);
        await context.SaveChangesAsync();
        NavigationManager.NavigateTo("/traits");
    }
}