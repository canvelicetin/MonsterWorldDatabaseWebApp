@page "/monster_habitat_loots/edit"
@using Microsoft.EntityFrameworkCore
@using ClassLibrary1
@using Microsoft.AspNetCore.Components.Web
@inject IDbContextFactory<BlazorApp1.Data.BlazorApp1Context> DbFactory
@inject NavigationManager NavigationManager

@rendermode RenderMode.InteractiveServer

<PageTitle>Edit</PageTitle>

<div class="page-container">
    <h1 class="page-title">Edit Drop Rule</h1>

    @if (MonsterHabitatLoot is null)
    {
        <p><em>Loading...</em></p>
    }
    else
    {
        <div class="ability-card" style="max-width: 600px;">
            <EditForm Model="MonsterHabitatLoot" OnValidSubmit="UpdateMonsterHabitatLoot">
                <DataAnnotationsValidator />
                <ValidationSummary role="alert" />

                <div class="form-group">
                    <label class="form-label" style="color:var(--text-secondary)">ID (Read-only):</label>
                    <input type="text" class="form-control" value="@MonsterHabitatLoot.ID" disabled readonly style="background-color: #2a2a2a; color: #888;" />
                </div>

                <div class="form-group">
                    <label class="form-label">Monster:</label>
                    <InputSelect @bind-Value="MonsterHabitatLoot.Monster_ID" class="form-control">
                        @foreach (var m in MonstersList)
                        {
                            <option value="@m.ID">@m.Name</option>
                        }
                    </InputSelect>
                </div>

                <div class="form-group">
                    <label class="form-label">Habitat:</label>
                    <InputSelect @bind-Value="MonsterHabitatLoot.Habitat_ID" class="form-control">
                        @foreach (var h in HabitatsList)
                        {
                            <option value="@h.ID">@h.Habitat_Name</option>
                        }
                    </InputSelect>
                </div>

                <div class="form-group">
                    <label class="form-label">Loot:</label>
                    <InputSelect @bind-Value="MonsterHabitatLoot.Loot_ID" class="form-control">
                        @foreach (var l in LootList)
                        {
                            <option value="@l.ID">@l.Loot_Name</option>
                        }
                    </InputSelect>
                </div>

                <div class="form-group">
                    <label class="form-label">Drop Rate:</label>
                    <InputNumber @bind-Value="MonsterHabitatLoot.Drop_Rate" class="form-control" step="0.01" />
                </div>

                <div style="margin-top: 2rem; display:flex; gap: 10px;">
                    <button type="submit" class="btn-action btn-primary">Save</button>
                    <a href="/monster_habitat_loots" class="btn-action btn-secondary">Cancel</a>
                </div>
            </EditForm>
        </div>
    }
</div>

@code {
    [SupplyParameterFromQuery]
    private int ID { get; set; }

    public Monster_Habitat_Loot? MonsterHabitatLoot { get; set; }

    private List<Monster> MonstersList = new();
    private List<Habitat> HabitatsList = new();
    private List<Loot> LootList = new();

    protected override async Task OnInitializedAsync()
    {
        using var context = DbFactory.CreateDbContext();

        // Önce kayıtlı veriyi çek
        MonsterHabitatLoot = await context.Monster_Habitat_Loot.FirstOrDefaultAsync(m => m.ID == ID);

        // Sonra dropdown listelerini doldur
        MonstersList = await context.Monster.OrderBy(m => m.Name).ToListAsync();
        HabitatsList = await context.Habitat.OrderBy(h => h.Habitat_Name).ToListAsync();
        LootList = await context.Loot.OrderBy(l => l.Loot_Name).ToListAsync();

        if (MonsterHabitatLoot is null)
        {
            NavigationManager.NavigateTo("notfound");
        }
    }

    private async Task UpdateMonsterHabitatLoot()
    {
        using var context = DbFactory.CreateDbContext();
        context.Attach(MonsterHabitatLoot!).State = EntityState.Modified;

        try
        {
            await context.SaveChangesAsync();
        }
        catch (DbUpdateConcurrencyException)
        {
            if (!context.Monster_Habitat_Loot.Any(e => e.ID == MonsterHabitatLoot!.ID))
            {
                NavigationManager.NavigateTo("notfound");
            }
            else
            {
                throw;
            }
        }
        NavigationManager.NavigateTo("/monster_habitat_loots");
    }
}