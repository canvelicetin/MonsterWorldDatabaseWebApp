@page "/monster_habitat_loots/delete"
@using Microsoft.EntityFrameworkCore
@using ClassLibrary1
@using Microsoft.AspNetCore.Components.Web
@inject IDbContextFactory<BlazorApp1.Data.BlazorApp1Context> DbFactory
@inject NavigationManager NavigationManager

@rendermode RenderMode.InteractiveServer

<PageTitle>Delete</PageTitle>

<div class="page-container">
    <h1 class="page-title" style="color:var(--danger-color)">Delete Drop Rule</h1>
    <p>Are you sure you want to delete this drop rule?</p>

    @if (MonsterHabitatLoot is null)
    {
        <p><em>Loading...</em></p>
    }
    else
    {
        <div class="ability-card" style="border-left: 5px solid var(--danger-color);">
            <div class="details-list">

                <div class="details-label">Monster</div>
                <div class="details-value">@MonsterHabitatLoot.Monster?.Name</div>

                <div class="details-label">Habitat</div>
                <div class="details-value">@MonsterHabitatLoot.Habitat?.Habitat_Name</div>

                <div class="details-label">Loot</div>
                <div class="details-value">@MonsterHabitatLoot.Loot?.Loot_Name</div>

                <div class="details-label">Drop Rate</div>
                <div class="details-value">@MonsterHabitatLoot.Drop_Rate</div>
            </div>

            <div style="margin-top: 2rem; display:flex; gap: 10px;">
                <button @onclick="DeleteMonsterHabitatLoot" class="btn-action btn-danger">Yes, Delete</button>
                <a href="/monster_habitat_loots" class="btn-action btn-secondary">No, Cancel</a>
            </div>
        </div>
    }
</div>

@code {
    [SupplyParameterFromQuery]
    private int ID { get; set; }

    public Monster_Habitat_Loot? MonsterHabitatLoot { get; set; }

    protected override async Task OnInitializedAsync()
    {
        using var context = DbFactory.CreateDbContext();
        MonsterHabitatLoot = await context.Monster_Habitat_Loot
            .Include(m => m.Monster)
            .Include(h => h.Habitat)
            .Include(l => l.Loot)
            .FirstOrDefaultAsync(m => m.ID == ID);

        if (MonsterHabitatLoot is null)
        {
            NavigationManager.NavigateTo("notfound");
        }
    }

    private async Task DeleteMonsterHabitatLoot()
    {
        using var context = DbFactory.CreateDbContext();
        context.Monster_Habitat_Loot.Remove(MonsterHabitatLoot!);
        await context.SaveChangesAsync();
        NavigationManager.NavigateTo("/monster_habitat_loots");
    }
}