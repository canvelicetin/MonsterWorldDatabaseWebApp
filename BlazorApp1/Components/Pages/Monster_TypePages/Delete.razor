@page "/monster_types/delete"
@using Microsoft.EntityFrameworkCore
@using ClassLibrary1
@using Microsoft.AspNetCore.Components.Web
@inject IDbContextFactory<BlazorApp1.Data.BlazorApp1Context> DbFactory
@inject NavigationManager NavigationManager

@rendermode RenderMode.InteractiveServer

<PageTitle>Delete</PageTitle>

<div class="page-container">
    <h1 class="page-title" style="color:var(--danger-color)">Delete Monster Type</h1>
    <p>Are you sure you want to delete this monster type?</p>

    @if (MonsterType is null)
    {
        <p><em>Loading...</em></p>
    }
    else
    {
        <div class="ability-card" style="border-left: 5px solid var(--danger-color);">
            <div class="details-list">
                <div class="details-label">ID</div>
                <div class="details-value">@MonsterType.ID</div>

                <div class="details-label">Type Name</div>
                <div class="details-value">@MonsterType.Type_Name</div>
            </div>

            <div style="margin-top: 2rem; display:flex; gap: 10px;">
                <button @onclick="DeleteMonsterType" class="btn-action btn-danger">Yes, Delete</button>
                <a href="/monster_types" class="btn-action btn-secondary">No, Cancel</a>
            </div>
        </div>
    }
</div>

@code {
    [SupplyParameterFromQuery]
    private int ID { get; set; }

    public Monster_Type? MonsterType { get; set; }

    protected override async Task OnInitializedAsync()
    {
        using var context = DbFactory.CreateDbContext();
        MonsterType = await context.Monster_Type.FirstOrDefaultAsync(m => m.ID == ID);

        if (MonsterType is null)
        {
            NavigationManager.NavigateTo("notfound");
        }
    }

    private async Task DeleteMonsterType()
    {
        using var context = DbFactory.CreateDbContext();
        context.Monster_Type.Remove(MonsterType!);
        await context.SaveChangesAsync();
        NavigationManager.NavigateTo("/monster_types");
    }
}