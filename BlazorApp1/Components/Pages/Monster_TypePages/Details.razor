@page "/monster_types/details"
@using Microsoft.EntityFrameworkCore
@using ClassLibrary1
@using Microsoft.AspNetCore.Components.Web
@inject IDbContextFactory<BlazorApp1.Data.BlazorApp1Context> DbFactory
@inject NavigationManager NavigationManager

@rendermode RenderMode.InteractiveServer

<PageTitle>Details</PageTitle>

<div class="page-container">
    <h1 class="page-title">Monster Type Details</h1>

    @if (MonsterType is null)
    {
        <p><em>Loading...</em></p>
    }
    else
    {
        <div class="ability-card">
            <div class="details-list">
                <div class="details-label">ID</div>
                <div class="details-value">@MonsterType.ID</div>

                <div class="details-label">Type Name</div>
                <div class="details-value">@MonsterType.Type_Name</div>
            </div>

            <div style="margin-top: 2rem; display:flex; gap: 10px;">
                <a href="@($"/monster_types/edit?id={MonsterType.ID}")" class="btn-action btn-primary">Edit</a>
                <a href="/monster_types" class="btn-action btn-secondary">Back to List</a>
            </div>
        </div>
    }
</div>

@code {
    [SupplyParameterFromQuery]
    private int ID { get; set; }

    public Monster_Type? MonsterType { get; set; }

    protected override async Task OnInitializedAsync()
    {
        using var context = DbFactory.CreateDbContext();
        MonsterType = await context.Monster_Type.FirstOrDefaultAsync(m => m.ID == ID);

        if (MonsterType is null)
        {
            NavigationManager.NavigateTo("notfound");
        }
    }
}