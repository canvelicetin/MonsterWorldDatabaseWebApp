@page "/monster_types/create"
@using Microsoft.EntityFrameworkCore
@using ClassLibrary1
@using Microsoft.AspNetCore.Components.Web
@inject IDbContextFactory<BlazorApp1.Data.BlazorApp1Context> DbFactory
@inject NavigationManager NavigationManager

@rendermode RenderMode.InteractiveServer

<PageTitle>Create Monster Type</PageTitle>

<div class="page-container">
    <h1 class="page-title">Create New Monster Type</h1>

    <div class="ability-card" style="max-width: 600px;">
        <EditForm Model="MonsterType" OnValidSubmit="AddMonsterType">
            <DataAnnotationsValidator />
            <ValidationSummary class="text-danger" role="alert" />

            <div class="form-group">
                <label for="type_name" class="form-label">Type Name:</label>
                <InputText id="type_name" @bind-Value="MonsterType.Type_Name" class="form-control" placeholder="Ex: Beast, Dragon, Elemental" />
                <ValidationMessage For="() => MonsterType.Type_Name" class="text-danger" />
            </div>

            <div style="margin-top: 2rem; display:flex; gap: 10px;">
                <button type="submit" class="btn-action btn-primary">Create</button>
                <a href="/monster_types" class="btn-action btn-secondary">Cancel</a>
            </div>
        </EditForm>
    </div>
</div>

@code {
    public Monster_Type MonsterType { get; set; } = new();

    private async Task AddMonsterType()
    {
        using var context = DbFactory.CreateDbContext();
        context.Monster_Type.Add(MonsterType);
        await context.SaveChangesAsync();
        NavigationManager.NavigateTo("/monster_types");
    }
}