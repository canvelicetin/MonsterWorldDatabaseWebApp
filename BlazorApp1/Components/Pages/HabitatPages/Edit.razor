@page "/habitats/edit"
@using Microsoft.EntityFrameworkCore
@using ClassLibrary1
@using Microsoft.AspNetCore.Components.Web
@inject IDbContextFactory<BlazorApp1.Data.BlazorApp1Context> DbFactory
@inject NavigationManager NavigationManager

@rendermode RenderMode.InteractiveServer

<PageTitle>Edit</PageTitle>

<div class="page-container">
    <h1 class="page-title">Edit Habitat</h1>

    @if (Habitat is null)
    {
        <p><em>Loading...</em></p>
    }
    else
    {
        <div class="ability-card" style="max-width: 600px;">
            <EditForm Model="Habitat" OnValidSubmit="UpdateHabitat">
                <DataAnnotationsValidator />
                <ValidationSummary role="alert" />

                <div class="form-group">
                    <label class="form-label" style="color:var(--text-secondary)">ID (Read-only):</label>
                    <input type="text" class="form-control" value="@Habitat.ID" disabled readonly style="background-color: #2a2a2a; color: #888;" />
                </div>

                <div class="form-group">
                    <label for="name" class="form-label">Habitat Name:</label>
                    <InputText id="name" @bind-Value="Habitat.Habitat_Name" class="form-control" />
                    <ValidationMessage For="() => Habitat.Habitat_Name" class="text-danger" />
                </div>

                <div class="form-group">
                    <label for="region" class="form-label">Region:</label>
                    <InputText id="region" @bind-Value="Habitat.Region" class="form-control" />
                    <ValidationMessage For="() => Habitat.Region" class="text-danger" />
                </div>

                <div style="margin-top: 2rem; display:flex; gap: 10px;">
                    <button type="submit" class="btn-action btn-primary">Save</button>
                    <a href="/habitats" class="btn-action btn-secondary">Cancel</a>
                </div>
            </EditForm>
        </div>
    }
</div>

@code {
    [SupplyParameterFromQuery]
    private int ID { get; set; }

    public Habitat? Habitat { get; set; }

    protected override async Task OnInitializedAsync()
    {
        using var context = DbFactory.CreateDbContext();
        Habitat = await context.Habitat.FirstOrDefaultAsync(m => m.ID == ID);

        if (Habitat is null)
        {
            NavigationManager.NavigateTo("notfound");
        }
    }

    private async Task UpdateHabitat()
    {
        using var context = DbFactory.CreateDbContext();
        context.Attach(Habitat!).State = EntityState.Modified;

        try
        {
            await context.SaveChangesAsync();
        }
        catch (DbUpdateConcurrencyException)
        {
            if (!HabitatExists(Habitat!.ID))
            {
                NavigationManager.NavigateTo("notfound");
            }
            else
            {
                throw;
            }
        }

        NavigationManager.NavigateTo("/habitats");
    }

    private bool HabitatExists(int id)
    {
        using var context = DbFactory.CreateDbContext();
        return context.Habitat.Any(e => e.ID == id);
    }
}