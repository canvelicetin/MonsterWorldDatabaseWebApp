@page "/habitats/delete"
@using Microsoft.EntityFrameworkCore
@using ClassLibrary1
@using Microsoft.AspNetCore.Components.Web
@inject IDbContextFactory<BlazorApp1.Data.BlazorApp1Context> DbFactory
@inject NavigationManager NavigationManager

@rendermode RenderMode.InteractiveServer

<PageTitle>Delete</PageTitle>

<div class="page-container">
    <h1 class="page-title" style="color:var(--danger-color)">Delete Habitat</h1>
    <p>Are you sure you want to delete this habitat?</p>

    @if (Habitat is null)
    {
        <p><em>Loading...</em></p>
    }
    else
    {
        <div class="ability-card" style="border-left: 5px solid var(--danger-color);">
            <div class="details-list">
                <div class="details-label">ID</div>
                <div class="details-value">@Habitat.ID</div>

                <div class="details-label">Habitat Name</div>
                <div class="details-value">@Habitat.Habitat_Name</div>

                <div class="details-label">Region</div>
                <div class="details-value">@Habitat.Region</div>
            </div>

            <div style="margin-top: 2rem; display:flex; gap: 10px;">
                <button @onclick="DeleteHabitat" class="btn-action btn-danger">Yes, Delete</button>
                <a href="/habitats" class="btn-action btn-secondary">No, Cancel</a>
            </div>
        </div>
    }
</div>

@code {
    [SupplyParameterFromQuery]
    private int ID { get; set; }

    public Habitat? Habitat { get; set; }

    protected override async Task OnInitializedAsync()
    {
        using var context = DbFactory.CreateDbContext();
        Habitat = await context.Habitat.FirstOrDefaultAsync(m => m.ID == ID);

        if (Habitat is null)
        {
            NavigationManager.NavigateTo("notfound");
        }
    }

    private async Task DeleteHabitat()
    {
        using var context = DbFactory.CreateDbContext();
        context.Habitat.Remove(Habitat!);
        await context.SaveChangesAsync();
        NavigationManager.NavigateTo("/habitats");
    }
}