@page "/monster_resistances/delete"
@using Microsoft.EntityFrameworkCore
@using ClassLibrary1
@using Microsoft.AspNetCore.Components.Web
@inject IDbContextFactory<BlazorApp1.Data.BlazorApp1Context> DbFactory
@inject NavigationManager NavigationManager

@rendermode RenderMode.InteractiveServer

<PageTitle>Delete</PageTitle>

<div class="page-container">
    <h1 class="page-title" style="color:var(--danger-color)">Delete Resistance</h1>
    <p>Are you sure you want to delete this resistance rule?</p>

    @if (MonsterResistances is null)
    {
        <p><em>Loading...</em></p>
    }
    else
    {
        <div class="ability-card" style="border-left: 5px solid var(--danger-color);">
            <div class="details-list">

                <div class="details-label">Monster</div>
                <div class="details-value">@MonsterResistances.Monster?.Name</div>

                <div class="details-label">Resistance Type</div>
                <div class="details-value">@MonsterResistances.Damage_Type?.Type_Name</div>
            </div>

            <div style="margin-top: 2rem; display:flex; gap: 10px;">
                <button @onclick="DeleteMonsterResistances" class="btn-action btn-danger">Yes, Delete</button>
                <a href="/monster_resistances" class="btn-action btn-secondary">No, Cancel</a>
            </div>
        </div>
    }
</div>

@code {
    [SupplyParameterFromQuery]
    private int ID { get; set; }

    public Monster_Resistances? MonsterResistances { get; set; }

    protected override async Task OnInitializedAsync()
    {
        using var context = DbFactory.CreateDbContext();

        MonsterResistances = await context.Monster_Resistances
            .Include(m => m.Monster)
            .Include(d => d.Damage_Type)
            .FirstOrDefaultAsync(m => m.ID == ID);

        if (MonsterResistances is null)
        {
            NavigationManager.NavigateTo("notfound");
        }
    }

    private async Task DeleteMonsterResistances()
    {
        using var context = DbFactory.CreateDbContext();
        context.Monster_Resistances.Remove(MonsterResistances!);
        await context.SaveChangesAsync();
        NavigationManager.NavigateTo("/monster_resistances");
    }
}