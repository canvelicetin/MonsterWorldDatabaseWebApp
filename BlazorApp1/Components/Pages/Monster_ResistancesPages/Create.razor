@page "/monster_resistances/create"
@using Microsoft.EntityFrameworkCore
@using ClassLibrary1
@using Microsoft.AspNetCore.Components.Web
@inject IDbContextFactory<BlazorApp1.Data.BlazorApp1Context> DbFactory
@inject NavigationManager NavigationManager

@rendermode RenderMode.InteractiveServer

<PageTitle>Create Resistance</PageTitle>

<div class="page-container">
    <h1 class="page-title">Create New Resistance</h1>
    <p style="color:var(--text-secondary)">Select monster and resistance type.</p>

    <div class="ability-card" style="max-width: 600px;">
        <EditForm Model="MonsterResistances" OnValidSubmit="AddMonsterResistances">
            <DataAnnotationsValidator />
            <ValidationSummary class="text-danger" role="alert" />

            <div class="form-group">
                <label class="form-label">Monster:</label>
                <InputSelect @bind-Value="MonsterResistances.Monster_ID" class="form-control">
                    <option value="0">-- Select a Monster --</option>
                    @foreach (var m in MonstersList)
                    {
                        <option value="@m.ID">@m.Name</option>
                    }
                </InputSelect>
                <ValidationMessage For="() => MonsterResistances.Monster_ID" class="text-danger" />
            </div>

            <div class="form-group">
                <label class="form-label">Resistance Type:</label>
                <InputSelect @bind-Value="MonsterResistances.DamageType_ID" class="form-control">
                    <option value="0">-- Select Damage Type --</option>
                    @foreach (var d in DamageTypesList)
                    {
                        <option value="@d.ID">@d.Type_Name</option>
                    }
                </InputSelect>
                <ValidationMessage For="() => MonsterResistances.DamageType_ID" class="text-danger" />
            </div>

            <div style="margin-top: 2rem; display:flex; gap: 10px;">
                <button type="submit" class="btn-action btn-primary">Create</button>
                <a href="/monster_resistances" class="btn-action btn-secondary">Cancel</a>
            </div>
        </EditForm>
    </div>
</div>

@code {
    public Monster_Resistances MonsterResistances { get; set; } = new();

    // Listeleri tutacak değişkenler
    private List<Monster> MonstersList = new();
    private List<Damage_Type> DamageTypesList = new();

    protected override async Task OnInitializedAsync()
    {
        using var context = DbFactory.CreateDbContext();

        // Veritabanından listeleri çekip dropdown'ları dolduruyoruz
        MonstersList = await context.Monster.OrderBy(m => m.Name).ToListAsync();
        DamageTypesList = await context.Damage_Type.OrderBy(d => d.Type_Name).ToListAsync();
    }

    private async Task AddMonsterResistances()
    {
        using var context = DbFactory.CreateDbContext();
        context.Monster_Resistances.Add(MonsterResistances);
        await context.SaveChangesAsync();
        NavigationManager.NavigateTo("/monster_resistances");
    }
}