@page "/monsters/delete"
@using Microsoft.EntityFrameworkCore
@using ClassLibrary1
@using Microsoft.AspNetCore.Components.Web
@inject IDbContextFactory<BlazorApp1.Data.BlazorApp1Context> DbFactory
@inject NavigationManager NavigationManager

@rendermode RenderMode.InteractiveServer

<PageTitle>Delete</PageTitle>

<div class="page-container">
    <h1 class="page-title" style="color:var(--danger-color)">Delete Monster</h1>
    <p>Are you sure you want to delete this monster?</p>

    @if (Monster is null)
    {
        <p><em>Loading...</em></p>
    }
    else
    {
        <div class="ability-card" style="border-left: 5px solid var(--danger-color);">
            <div class="details-list">
                <div class="details-label">ID</div>
                <div class="details-value">@Monster.ID</div>

                <div class="details-label">Monster Name</div>
                <div class="details-value">@Monster.Name</div>

                <div class="details-label">Challenge Rating</div>
                <div class="details-value">@Monster.Challenge_Rating</div>
            </div>

            <div style="margin-top: 2rem; display:flex; gap: 10px;">
                <button @onclick="DeleteMonster" class="btn-action btn-danger">Yes, Delete</button>
                <a href="/monsters" class="btn-action btn-secondary">No, Cancel</a>
            </div>
        </div>
    }
</div>

@code {
    [SupplyParameterFromQuery]
    private int ID { get; set; }

    public Monster? Monster { get; set; }

    protected override async Task OnInitializedAsync()
    {
        using var context = DbFactory.CreateDbContext();
        Monster = await context.Monster.FirstOrDefaultAsync(m => m.ID == ID);

        if (Monster is null)
        {
            NavigationManager.NavigateTo("notfound");
        }
    }

    private async Task DeleteMonster()
    {
        using var context = DbFactory.CreateDbContext();
        context.Monster.Remove(Monster!);
        await context.SaveChangesAsync();
        NavigationManager.NavigateTo("/monsters");
    }
}