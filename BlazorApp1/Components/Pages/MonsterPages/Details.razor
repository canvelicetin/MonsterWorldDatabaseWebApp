@page "/monsters/details"
@using Microsoft.EntityFrameworkCore
@using ClassLibrary1
@using Microsoft.AspNetCore.Components.Web
@inject IDbContextFactory<BlazorApp1.Data.BlazorApp1Context> DbFactory
@inject NavigationManager NavigationManager

@rendermode RenderMode.InteractiveServer

<PageTitle>Details</PageTitle>

<div class="page-container">
    <h1 class="page-title">Monster Details</h1>

    @if (Monster is null)
    {
        <p><em>Loading...</em></p>
    }
    else
    {
        <div class="ability-card">
            <div class="details-list">
                <div class="details-label">ID</div>
                <div class="details-value">@Monster.ID</div>

                <div class="details-label">Monster Name</div>
                <div class="details-value">@Monster.Name</div>

                <div class="details-label">Challenge Rating (CR)</div>
                <div class="details-value" style="color:var(--primary-color); font-weight:bold;">@Monster.Challenge_Rating</div>

                <div class="details-label">Type ID</div>
                <div class="details-value">@Monster.Monster_Type_ID</div>
            </div>

            <div style="margin-top: 2rem; display:flex; gap: 10px;">
                <a href="@($"/monsters/edit?id={Monster.ID}")" class="btn-action btn-primary">Edit</a>
                <a href="/monsters" class="btn-action btn-secondary">Back to List</a>
            </div>
        </div>
    }
</div>

@code {
    [SupplyParameterFromQuery]
    private int ID { get; set; }

    public Monster? Monster { get; set; }

    protected override async Task OnInitializedAsync()
    {
        using var context = DbFactory.CreateDbContext();
        Monster = await context.Monster.FirstOrDefaultAsync(m => m.ID == ID);

        if (Monster is null)
        {
            NavigationManager.NavigateTo("notfound");
        }
    }
}