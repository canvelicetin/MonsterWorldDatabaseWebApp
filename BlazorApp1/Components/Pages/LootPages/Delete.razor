@page "/loots/delete"
@using Microsoft.EntityFrameworkCore
@using ClassLibrary1
@using Microsoft.AspNetCore.Components.Web
@inject IDbContextFactory<BlazorApp1.Data.BlazorApp1Context> DbFactory
@inject NavigationManager NavigationManager

@rendermode RenderMode.InteractiveServer

<PageTitle>Delete</PageTitle>

<div class="page-container">
    <h1 class="page-title" style="color:var(--danger-color)">Delete Loot</h1>
    <p>Are you sure you want to delete this loot?</p>

    @if (Loot is null)
    {
        <p><em>Loading...</em></p>
    }
    else
    {
        <div class="ability-card" style="border-left: 5px solid var(--danger-color);">
            <div class="details-list">
                <div class="details-label">ID</div>
                <div class="details-value">@Loot.ID</div>

                <div class="details-label">Loot Name</div>
                <div class="details-value">@Loot.Loot_Name</div>

                <div class="details-label">Rarity</div>
                <div class="details-value">@Loot.Rarity</div>
            </div>

            <div style="margin-top: 2rem; display:flex; gap: 10px;">
                <button @onclick="DeleteLoot" class="btn-action btn-danger">Yes, Delete</button>
                <a href="/loots" class="btn-action btn-secondary">No, Cancel</a>
            </div>
        </div>
    }
</div>

@code {
    [SupplyParameterFromQuery]
    private int ID { get; set; }

    public Loot? Loot { get; set; }

    protected override async Task OnInitializedAsync()
    {
        using var context = DbFactory.CreateDbContext();
        Loot = await context.Loot.FirstOrDefaultAsync(m => m.ID == ID);

        if (Loot is null)
        {
            NavigationManager.NavigateTo("notfound");
        }
    }

    private async Task DeleteLoot()
    {
        using var context = DbFactory.CreateDbContext();
        context.Loot.Remove(Loot!);
        await context.SaveChangesAsync();
        NavigationManager.NavigateTo("/loots");
    }
}