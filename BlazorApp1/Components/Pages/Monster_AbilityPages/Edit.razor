@page "/monster_abilities/edit"
@using Microsoft.EntityFrameworkCore
@using ClassLibrary1
@using Microsoft.AspNetCore.Components.Web
@inject IDbContextFactory<BlazorApp1.Data.BlazorApp1Context> DbFactory
@inject NavigationManager NavigationManager

@rendermode RenderMode.InteractiveServer

<PageTitle>Düzenle</PageTitle>

<div class="page-container">
    <h1 class="page-title">Atamayı Düzenle</h1>

    @if (MonsterAbility is null)
    {
        <p><em>Yükleniyor...</em></p>
    }
    else
    {
        <div class="ability-card" style="max-width: 600px;">
            <EditForm Model="MonsterAbility" OnValidSubmit="UpdateMonsterAbility">
                <DataAnnotationsValidator />
                <ValidationSummary role="alert" />

                <div class="form-group">
                    <label class="form-label" style="color:var(--text-secondary)">ID (Salt Okunur):</label>
                    <input type="text" class="form-control" value="@MonsterAbility.ID" disabled readonly style="background-color: #2a2a2a; color: #888;" />
                </div>

                <div class="form-group">
                    <label class="form-label">Canavar:</label>
                    <InputSelect @bind-Value="MonsterAbility.Monster_ID" class="form-control">
                        @foreach (var m in MonstersList)
                        {
                            <option value="@m.ID">@m.Name</option>
                        }
                    </InputSelect>
                </div>

                <div class="form-group">
                    <label class="form-label">Yetenek:</label>
                    <InputSelect @bind-Value="MonsterAbility.Ability_ID" class="form-control">
                        @foreach (var a in AbilitiesList)
                        {
                            <option value="@a.ID">@a.Name</option>
                        }
                    </InputSelect>
                </div>

                <div style="margin-top: 2rem; display:flex; gap: 10px;">
                    <button type="submit" class="btn-action btn-primary">Kaydet</button>
                    <a href="/monster_abilities" class="btn-action btn-secondary">İptal</a>
                </div>
            </EditForm>
        </div>
    }
</div>

@code {
    [SupplyParameterFromQuery]
    private int ID { get; set; }

    public Monster_Abilities? MonsterAbility { get; set; }
    private List<Monster> MonstersList = new();
    private List<Ability> AbilitiesList = new();

    protected override async Task OnInitializedAsync()
    {
        using var context = DbFactory.CreateDbContext();
        MonsterAbility = await context.Monster_Abilities.FirstOrDefaultAsync(m => m.ID == ID);
        MonstersList = await context.Monster.OrderBy(m => m.Name).ToListAsync();

        // --- DÜZELTME BURADA YAPILDI (Abilities -> Ability) ---
        AbilitiesList = await context.Ability.OrderBy(a => a.Name).ToListAsync();

        if (MonsterAbility is null) NavigationManager.NavigateTo("notfound");
    }

    private async Task UpdateMonsterAbility()
    {
        using var context = DbFactory.CreateDbContext();
        context.Attach(MonsterAbility!).State = EntityState.Modified;
        try { await context.SaveChangesAsync(); }
        catch (DbUpdateConcurrencyException) { throw; }
        NavigationManager.NavigateTo("/monster_abilities");
    }
}