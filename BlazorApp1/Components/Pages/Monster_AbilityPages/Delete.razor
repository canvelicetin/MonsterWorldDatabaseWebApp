@page "/monster_abilities/delete"
@using Microsoft.EntityFrameworkCore
@using ClassLibrary1
@using Microsoft.AspNetCore.Components.Web
@inject IDbContextFactory<BlazorApp1.Data.BlazorApp1Context> DbFactory
@inject NavigationManager NavigationManager

@rendermode RenderMode.InteractiveServer

<PageTitle>Delete</PageTitle>

<div class="page-container">
    <h1 class="page-title" style="color:var(--danger-color)">Delete Assignment</h1>
    <p>Are you sure you want to remove this ability from the monster?</p>

    @if (MonsterAbility is null)
    {
        <p><em>Loading...</em></p>
    }
    else
    {
        <div class="ability-card" style="border-left: 5px solid var(--danger-color);">
            <div class="details-list">
                <div class="details-label">Monster</div>
                <div class="details-value">@MonsterAbility.Monster?.Name</div>

                <div class="details-label">Ability</div>
                <div class="details-value">@MonsterAbility.Ability?.Name</div>
            </div>

            <div style="margin-top: 2rem; display:flex; gap: 10px;">
                <button @onclick="DeleteMonsterAbility" class="btn-action btn-danger">Yes, Delete</button>
                <a href="/monster_abilities" class="btn-action btn-secondary">No, Cancel</a>
            </div>
        </div>
    }
</div>

@code {
    [SupplyParameterFromQuery]
    private int ID { get; set; }

    public Monster_Abilities? MonsterAbility { get; set; }

    protected override async Task OnInitializedAsync()
    {
        using var context = DbFactory.CreateDbContext();

        MonsterAbility = await context.Monster_Abilities
            .Include(m => m.Monster)
            .Include(a => a.Ability)
            .FirstOrDefaultAsync(m => m.ID == ID);

        if (MonsterAbility is null)
        {
            NavigationManager.NavigateTo("notfound");
        }
    }

    private async Task DeleteMonsterAbility()
    {
        using var context = DbFactory.CreateDbContext();
        context.Monster_Abilities.Remove(MonsterAbility!);
        await context.SaveChangesAsync();
        NavigationManager.NavigateTo("/monster_abilities");
    }
}