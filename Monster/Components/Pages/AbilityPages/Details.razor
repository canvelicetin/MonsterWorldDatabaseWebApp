@page "/abilities/details"
@using Microsoft.EntityFrameworkCore
@using monsterr
@inject IDbContextFactory<Monster.Data.MonsterContext> DbFactory
@inject NavigationManager NavigationManager

<PageTitle>Details</PageTitle>

<h1>Details</h1>

<div>
    <h2>Ability</h2>
    <hr />
    @if (ability is null)
    {
        <p><em>Loading...</em></p>
    }
    else {
        <dl class="row">
            <dt class="col-sm-2">Name</dt>
            <dd class="col-sm-10">@ability.Name</dd>
            <dt class="col-sm-2">Description</dt>
            <dd class="col-sm-10">@ability.Description</dd>
        </dl>
        <div>
            <a href="@($"/abilities/edit?id={ability.ID}")">Edit</a> |
            <a href="@($"/abilities")">Back to List</a>
        </div>
    }
</div>

@code {
    private Ability? ability;

    [SupplyParameterFromQuery]
    private int ID { get; set; }

    protected override async Task OnInitializedAsync()
    {
        using var context = DbFactory.CreateDbContext();
        ability = await context.Ability.FirstOrDefaultAsync(m => m.ID == ID);

        if (ability is null)
        {
            NavigationManager.NavigateTo("notfound");
        }
    }
}
