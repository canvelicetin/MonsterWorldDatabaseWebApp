@page "/abilities"
@using Microsoft.EntityFrameworkCore
@using Microsoft.AspNetCore.Components.QuickGrid
@using monsterr
@using Monster.Data
@implements IAsyncDisposable
@inject IDbContextFactory<Monster.Data.MonsterContext> DbFactory

<PageTitle>Index</PageTitle>

<h1>Index</h1>

<p>
    <a href="abilities/create">Create New</a>
</p>

<QuickGrid Class="table" Items="context.Ability">
    <PropertyColumn Property="ability => ability.Name" />
    <PropertyColumn Property="ability => ability.Description" />

    <TemplateColumn Context="ability">
        <a href="@($"abilities/edit?id={ability.ID}")">Edit</a> |
        <a href="@($"abilities/details?id={ability.ID}")">Details</a> |
        <a href="@($"abilities/delete?id={ability.ID}")">Delete</a>
    </TemplateColumn>
</QuickGrid>

@code {
    private MonsterContext context = default!;

    protected override void OnInitialized()
    {
        context = DbFactory.CreateDbContext();
    }

    public async ValueTask DisposeAsync() => await context.DisposeAsync();
}
