@page "/abilities/delete"
@using Microsoft.EntityFrameworkCore
@using monsterr
@inject IDbContextFactory<Monster.Data.MonsterContext> DbFactory
@inject NavigationManager NavigationManager

<PageTitle>Delete</PageTitle>

<h1>Delete</h1>

<p>Are you sure you want to delete this?</p>
<div>
    <h2>Ability</h2>
    <hr />
    @if (ability is null)
    {
        <p><em>Loading...</em></p>
    }
    else {
        <dl class="row">
            <dt class="col-sm-2">Name</dt>
            <dd class="col-sm-10">@ability.Name</dd>
        </dl>
        <dl class="row">
            <dt class="col-sm-2">Description</dt>
            <dd class="col-sm-10">@ability.Description</dd>
        </dl>
        <EditForm method="post" Model="ability" OnValidSubmit="DeleteAbility" FormName="delete" Enhance>
            <button type="submit" class="btn btn-danger" disabled="@(ability is null)">Delete</button> |
            <a href="/abilities">Back to List</a>
        </EditForm>
    }
</div>

@code {
    private Ability? ability;

    [SupplyParameterFromQuery]
    private int ID { get; set; }

    protected override async Task OnInitializedAsync()
    {
        using var context = DbFactory.CreateDbContext();
        ability = await context.Ability.FirstOrDefaultAsync(m => m.ID == ID);

        if (ability is null)
        {
            NavigationManager.NavigateTo("notfound");
        }
    }

    private async Task DeleteAbility()
    {
        using var context = DbFactory.CreateDbContext();
        context.Ability.Remove(ability!);
        await context.SaveChangesAsync();
        NavigationManager.NavigateTo("/abilities");
    }
}
